NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
PERSISTENCE_MODE=file
DATABASE_URL=postgres://inspectiq:inspectiq@localhost:5432/inspectiq
DATABASE_SECRET_ARN=
VISION_PROVIDER=local
REPORT_PROVIDER=local
IMAGE_UPLOAD_MODE=local
IMAGE_ANALYSIS_MODE=inline
ENABLE_REFERENCE_EVIDENCE=true
ENABLE_EVALUATION_MODE=true
IMAGE_BUCKET=
IMAGE_ANALYSIS_QUEUE_URL=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_VISION_FALLBACK=local
MIN_DAMAGE_CONFIDENCE=0.80
AUTH_MODE=headers
OIDC_ISSUER=
OIDC_AUDIENCE=
DEFAULT_AUTH_ROLE=inspector
REQUIRE_JWT_ROLE_CLAIM=false
AUTH_ADMIN_EMAILS=
AUTH_REVIEWER_EMAILS=
AUTH_INSPECTOR_EMAILS=
GRADING_SERVICE_URL=http://localhost:8080
LOG_LEVEL=info
VITE_AUTH_MODE=
VITE_DEFAULT_AUTH_ROLE=inspector
VITE_ENABLE_REFERENCE_EVIDENCE=true
VITE_ENABLE_EVALUATION_MODE=true
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=
VITE_COGNITO_LOGOUT_URI=
