{
  "name": "@inspectiq/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@inspectiq/shared": "^0.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "base64-js": "^1.5.1",
    "expo": "~57.0.4",
    "expo-application": "~57.0.0",
    "expo-auth-session": "~57.0.2",
    "expo-camera": "~57.0.1",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-network": "~57.0.0",
    "expo-secure-store": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "jpeg-js": "^0.4.4",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/base64-js": "^1.3.2",
    "@types/jest": "29.5.14",
    "@types/jpeg-js": "^0.3.0",
    "@types/react": "~19.2.2",
    "jest-expo": "~57.0.1",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "build:android:apk": "bash ./scripts/build-android-apk.sh",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|expo-.*|@expo/.*|@react-navigation/.*|react-native-svg|lucide-react-native))"
    ]
  },
  "private": true
}
